// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id              String    @id
  email           String?   @unique
  name            String?
  accessExpiresAt DateTime?
  role            String    @default("user")
  isActive        Boolean   @default(true)

  attempts     UserAttempt[]
  testimonials Testimonial[]

  customsSimulatorProgress CustomsSimulatorProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupId  String?
  group    Group?   @relation(fields: [groupId], references: [id])
  groupIds String[] @default([])

  enrolledCourseSlugs String[] @default([])

  @@index([groupId])
}

model CustomsSimulatorProgress {
  id              String    @id @default(cuid())
  profileId       String
  profile         Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  /// caseKey coincide con JSON + segmento URL
  caseKey         String
  /// Pipeline §6.4: expediente, analisis, …
  currentStepSlug String
  /// Respuestas agregadas (claves planas por id de pregunta/campo)
  answers         Json      @default("{}")
  /// Ids de eventos Journey resueltos (MVP: array JSON)
  journeyResolved Json      @default("[]")
  /// Etapas completadas orden contiguo desde expediente
  completedStages Json      @default("[]")
  scorePercent    Int?
  evaluatedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, caseKey])
  @@index([profileId])
  @@index([caseKey])
}

model Testimonial {
  id         String @id @default(cuid())
  text       String
  rating     Int // 1-5
  status     String @default("pending") // "pending" | "published"
  /// Slug de curso: `anexo22` | `clasificacion-arancelaria` | `simulador-aduanero` (ver COURSES)
  courseSlug String

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, courseSlug])
  @@index([status, courseSlug])
}

model UserAttempt {
  id String @id @default(cuid())

  userAnswers Json

  evaluatedAt DateTime?

  caseStudyId String

  // Relación con el usuario que hizo el intento
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, caseStudyId, evaluatedAt])
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  youtubeId   String   @unique
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([groupId])
}

// --- NUEVO MODELO ---
model Group {
  id         String  @id @default(cuid())
  name       String  @unique
  courseSlug String? // "anexo22" | "clasificacion-arancelaria"

  // Relaciones
  profiles Profile[]
  videos   Video[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
